# Configuração do ambiente
# ENV_TYPE pode ser:
# - DEVELOPMENT: para ambiente de desenvolvimento/testes
# - PRODUCTION: para ambiente de produção
ENV_TYPE=DEVELOPMENT

# Tokens do Discord bot
TOKEN_BOT=""
TOKEN_BOT_TEST=""

# Autenticação na API Timbas (deve ser igual ao BOT_SECRET da API)
BOT_SECRET="a-long-random-secret-string"

# URL base da API Timbas (sem barra no final)
TIMBAS_API_URL=""